# Bazodiac Fusion Preview — environment variables.
#
# Defaults are stub-mode-friendly: with no variables set, the server
# returns deterministic fixture-backed responses and the frontend can be
# deployed to Railway without any upstream services. To engage real
# providers, flip PUBLIC_API_STUB_MODE=false and supply the credentials
# below.

# --- Runtime ---
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
CORS_ORIGIN=*

# --- Stub mode toggle ---
# When true (default), all endpoints return deterministic fixture data
# from contracts/fixtures/*.json. When false, the server requires every
# provider variable below to be set; missing values cause a startup-time
# CONFIGURATION_ERROR.
PUBLIC_API_STUB_MODE=true

# --- FuFirE chart engine (POST {FUFIRE_BASE_URL}/chart, header X-API-Key) ---
FUFIRE_BASE_URL=https://bafe-production.up.railway.app
FUFIRE_API_KEY=
FUFIRE_TIMEOUT_MS=15000

# --- Geocoding + timezone resolution ---
# Vendor-specific URLs and keys (Mapbox, Google, OpenCage, etc.). The
# adapter passes ?q=<birthPlace> to the geocoder and ?lat=&lon= to the
# timezone resolver; adjust src/providers/geocodingProvider.mjs for the
# selected vendor's exact request/response shape.
GEOCODING_API_URL=
GEOCODING_API_KEY=
TIMEZONE_API_URL=
TIMEZONE_API_KEY=

# --- Interpretation (Gemini or proxy) ---
INTERPRETATION_API_URL=
GEMINI_API_KEY=

# --- Newsletter signup vendor ---
NEWSLETTER_API_URL=
NEWSLETTER_API_KEY=
